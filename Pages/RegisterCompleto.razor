@page "/"
@inject SessionService SessionService
@inject NavigationManager Navigation

<p>Redirecionando...</p>

@code {
    protected override async Task OnInitializedAsync()
    {
        var email = await SessionService.GetUserEmailAsync();
        Navigation.NavigateTo(string.IsNullOrWhiteSpace(email) ? "/login" : "/dashboard", true);
    }
}
