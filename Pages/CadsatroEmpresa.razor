@page "/CadastroEmpresa"
@inject API ApiService
@inject NavigationManager Navigation
@inject SessionService SessionService

<AuthGuard>
    <AppShell Title="Empresas" Subtitle="Cadastre e acompanhe as empresas vinculadas ao ambiente para manter a estrutura organizacional pronta para escalar.">
        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="alert @AlertClass">@Message</div>
        }

        <div class="home-grid">
            <section class="card">
                <h3>Nova empresa</h3>

                <div class="home-form-grid">
                    <div>
                        <label class="form-label">Nome</label>
                        <input class="form-control" @bind="Empresa.Nome" />
                    </div>

                    <div>
                        <label class="form-label">CNPJ</label>
                        <input class="form-control" @bind="Empresa.CNPJ" />
                    </div>

                    <div>
                        <label class="form-label">Endereco</label>
                        <input class="form-control" @bind="Empresa.Endereco" />
                    </div>

                    <div>
                        <label class="form-label">Telefone</label>
                        <input class="form-control" @bind="Empresa.Telefone" />
                    </div>

                    <div>
                        <label class="form-label">Email</label>
                        <input class="form-control" @bind="Empresa.Email" />
                    </div>

                    <div>
                        <label class="form-label">Representante legal</label>
                        <input class="form-control" @bind="Empresa.RepresentanteLegal" />
                    </div>

                    <div>
                        <label class="form-label">Data de fundacao</label>
                        <InputDate @bind-Value="Empresa.DataFundacao" class="form-control" />
                    </div>
                </div>

                <button class="btn btn-success mt-3" @onclick="CadastrarEmpresa">Salvar empresa</button>
            </section>

            <section class="card">
                <h3>Empresas cadastradas</h3>

                @if (ListaEmpresas?.Any() == true)
                {
                    <div class="home-info-list">
                        @foreach (var empresa in ListaEmpresas)
                        {
                            <article class="home-metric">
                                <span>@empresa.CNPJ</span>
                                <strong>@empresa.Nome</strong>
                                <small>@empresa.Endereco</small>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="text-muted">Nenhuma empresa cadastrada ainda.</div>
                }
            </section>
        </div>
    </AppShell>
</AuthGuard>

@code {
    private Empresa Empresa = new();
    private List<Empresa>? ListaEmpresas = new();
    private string Message = string.Empty;
    private string AlertClass = "alert-success";
    private string? UsuarioEmail;

    protected override async Task OnInitializedAsync()
    {
        UsuarioEmail = await SessionService.GetUserEmailAsync();
        if (string.IsNullOrWhiteSpace(UsuarioEmail))
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        Empresa.Email = UsuarioEmail;
        Empresa.RepresentanteLegal = UsuarioEmail;
        await CarregarEmpresas();
    }

    private async Task CarregarEmpresas()
    {
        if (string.IsNullOrWhiteSpace(UsuarioEmail))
        {
            ListaEmpresas = new();
            return;
        }

        ListaEmpresas = await ApiService.GetEmpresasAsync(UsuarioEmail) ?? new();
    }

    private async Task CadastrarEmpresa()
    {
        if (string.IsNullOrWhiteSpace(Empresa.Nome) || string.IsNullOrWhiteSpace(Empresa.CNPJ))
        {
            Message = "Nome e CNPJ sao obrigatorios.";
            AlertClass = "alert-danger";
            return;
        }

        Empresa.Email ??= UsuarioEmail;
        Empresa.RepresentanteLegal ??= UsuarioEmail;

        var sucesso = await ApiService.PostEmpresa(Empresa);
        if (sucesso)
        {
            Message = "Empresa cadastrada com sucesso.";
            AlertClass = "alert-success";
            Empresa = new Empresa
            {
                Email = UsuarioEmail,
                RepresentanteLegal = UsuarioEmail
            };
            await CarregarEmpresas();
        }
        else
        {
            Message = "Erro ao cadastrar empresa.";
            AlertClass = "alert-danger";
        }
    }
}
