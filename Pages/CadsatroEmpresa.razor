@page "/CadastroEmpresa"
@inject API ApiService
@inject NavigationManager Navigation
@using pRHosaApp1.Models
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
<h3 class="mb-4">🏢 Cadastro de Empresas</h3>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert @AlertClass">@Message</div>
}

<div class="card p-4 mb-4 shadow-sm">
    <h5 class="mb-3">Nova Empresa</h5>

    <div class="mb-2">
        <label class="form-label">Nome:</label>
        <input class="form-control" @bind="Empresa.Nome" />
    </div>

    <div class="mb-2">
        <label class="form-label">CNPJ:</label>
        <input class="form-control" @bind="Empresa.CNPJ" />
    </div>

    <div class="mb-2">
        <label class="form-label">Endereço:</label>
        <input class="form-control" @bind="Empresa.Endereco" />
    </div>

    <div class="mb-2">
        <label class="form-label">Telefone:</label>
        <input class="form-control" @bind="Empresa.Telefone" />
    </div>

    <div class="mb-2">
        <label class="form-label">Email:</label>
        <input class="form-control" @bind="Empresa.Email" />
    </div>

    <div class="mb-2">
        <label class="form-label">Representante Legal:</label>
        <input class="form-control" @bind="Empresa.RepresentanteLegal" />
    </div>

    <div class="mb-3">
        <label class="form-label">Data de Fundação:</label>
        <input type="date" class="form-control" @bind-value="Empresa.DataFundacao" @bind-value:event="oninput" />
    </div>
    <button class="btn btn-success w-100" @onclick="CadastrarEmpresa">Salvar Empresa</button>
</div>

<h5 class="mb-3">📋 Empresas Cadastradas</h5>
@if (ListaEmpresas?.Any() == true)
{
    <ul class="list-group">
        @foreach (var empresa in ListaEmpresas)
        {
            <li class="list-group-item">
                <b>@empresa.Nome</b> – @empresa.CNPJ<br />
                <small>@empresa.Endereco</small>
            </li>
        }
    </ul>
}
else
{
    <div class="text-muted">Nenhuma empresa cadastrada ainda.</div>
}

@code {
    private Empresa Empresa = new();
    private List<Empresa>? ListaEmpresas = new();
    private string Message = "";
    private string AlertClass = "";
    private string? UsuarioEmail;

    protected override async Task OnInitializedAsync()
    {
        UsuarioEmail = await LocalStorage.GetItemAsync<string>("usuario_email");

        if (string.IsNullOrEmpty(UsuarioEmail))
        {
            Navigation.NavigateTo("/login", true);
            return;
        }
        await CarregarEmpresas();
    }
    private string? DataFundacaoString
    {
        get => Empresa.DataFundacao?.ToString("yyyy-MM-dd");
        set
        {
            if (DateTime.TryParse(value, out var dt))
                Empresa.DataFundacao = dt;
        }
    }

    private async Task CarregarEmpresas()
    {
        ListaEmpresas = await ApiService.GetEmpresasAsync(UsuarioEmail) ?? new List<Empresa>();
    }

    private async Task CadastrarEmpresa()
    {
        if (string.IsNullOrWhiteSpace(Empresa.Nome) || string.IsNullOrWhiteSpace(Empresa.CNPJ))
        {
            Message = "Nome e CNPJ são obrigatórios.";
            AlertClass = "alert-danger";
            return;
        }

        var sucesso = await ApiService.PostEmpresa(Empresa);
        if (sucesso)
        {
            Message = "✅ Empresa cadastrada com sucesso!";
            AlertClass = "alert-success";
            Empresa = new();
            await CarregarEmpresas();
        }
        else
        {
            Message = "❌ Erro ao cadastrar empresa.";
            AlertClass = "alert-danger";
        }
    }
}
