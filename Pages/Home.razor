    private async Task CarregarGestaoAsync(string email)
    {
        UsuariosGestao = await ApiService.GetUsuariosGestao(email) ?? new();
        ResumoOperacao = await ApiService.GetResumoOperacao(email);
        Cargos = await ApiService.GetCargosPorEmail(email) ?? new();

        if (EmpresaPrincipal is null)
        {
            Colaboradores = MesclarColaboradores([]);
            return;
        }

        var colaboradores = await ApiService.GetColaboradoresAsync(EmpresaPrincipal.EmpresaId) ?? new();
        Colaboradores = MesclarColaboradores(colaboradores);
    }

    private List<ColaboradorInfo> MesclarColaboradores(IEnumerable<ColaboradorInfo> colaboradoresBase)
    {
        var colaboradores = colaboradoresBase
            .Select(colaborador => new ColaboradorInfo
            {
                Id = colaborador.Id,
                Nome = colaborador.Nome,
                CPF = colaborador.CPF,
                EmpresaId = colaborador.EmpresaId,
                Email = colaborador.Email,
                TipoUsuario = colaborador.TipoUsuario,
                Cargo = colaborador.Cargo
            })
            .ToDictionary(
                colaborador => colaborador.Email.Trim().ToLowerInvariant(),
                colaborador => colaborador);

        foreach (var usuario in UsuariosGestao)
        {
            var email = (usuario.Email ?? string.Empty).Trim().ToLowerInvariant();
            if (string.IsNullOrWhiteSpace(email))
            {
                continue;
            }

            if (!colaboradores.TryGetValue(email, out var colaborador))
            {
                if (string.IsNullOrWhiteSpace(usuario.ColaboradorNome))
                {
                    continue;
                }

                colaborador = new ColaboradorInfo
                {
                    Id = usuario.Id,
                    Nome = usuario.ColaboradorNome ?? usuario.Email ?? string.Empty,
                    CPF = usuario.CPF ?? string.Empty,
                    Email = usuario.Email ?? string.Empty,
                    EmpresaId = usuario.EmpresaId ?? EmpresaPrincipal?.EmpresaId ?? 0,
                    TipoUsuario = usuario.TipoUsuario ?? 0,
                    Cargo = usuario.Cargo ?? string.Empty
                };

                colaboradores[email] = colaborador;
                continue;
            }

            if (colaborador.TipoUsuario == 0 && usuario.TipoUsuario.HasValue)
            {
                colaborador.TipoUsuario = usuario.TipoUsuario.Value;
            }

            if (string.IsNullOrWhiteSpace(colaborador.Cargo) && !string.IsNullOrWhiteSpace(usuario.Cargo))
            {
                colaborador.Cargo = usuario.Cargo;
            }

            if (string.IsNullOrWhiteSpace(colaborador.Nome) && !string.IsNullOrWhiteSpace(usuario.ColaboradorNome))
            {
                colaborador.Nome = usuario.ColaboradorNome;
            }

            if (string.IsNullOrWhiteSpace(colaborador.CPF) && !string.IsNullOrWhiteSpace(usuario.CPF))
            {
                colaborador.CPF = usuario.CPF;
            }
        }

        return colaboradores.Values.OrderBy(colaborador => colaborador.Nome).ToList();
    }

    private static string TipoUsuarioDescricao(int? tipo) => tipo switch
    {
        1 => "Usuario RH",
        2 => "Usuario Apoio",
        3 => "Usuario Colaborador",
        4 => "Usuario Diretoria",
        _ => "Sem tipo definido"
    };

    private static string FormatarCpf(string? cpf)
    {
        var apenasNumeros = new string((cpf ?? string.Empty).Where(char.IsDigit).ToArray());
        if (apenasNumeros.Length != 11)
        {
            return string.IsNullOrWhiteSpace(cpf) ? "Nao informado" : cpf;
        }

        return Convert.ToUInt64(apenasNumeros).ToString(@"000\.000\.000\-00");
    }
