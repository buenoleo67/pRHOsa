@page "/home"
@inject API ApiService
@inject SessionService SessionService
@inject NavigationManager Navigation
@inject NotificationService NotificationService

<AuthGuard>
    <AppShell Title="Visao geral" Subtitle="Centralize cadastros, acompanhe a conta e organize a base da operacao antes de escalar o time.">
        @if (Carregando)
        {
            <div class="loading-progress"></div>
        }
        else if (!string.IsNullOrEmpty(MensagemErro))
        {
            <div class="alert alert-danger">@MensagemErro</div>
        }
        else if (Usuario is not null)
        {
            <section class="home-hero card">
                <div>
                    <span class="home-pill">Conta ativa</span>
                    <h2>Bem-vindo, @NomeApresentacao.</h2>
                    <p class="text-muted">
                        Seu espaco de operacao esta pronto para administrar acessos, colaboradores, tipos de necessidade, cargos e empresas com mais clareza.
                    </p>
                </div>

                <div class="home-metric-grid">
                    <article class="home-metric">
                        <span>Perfil</span>
                        <strong>@PerfilUsuario</strong>
                        <small>Controle principal da conta</small>
                    </article>
                    <article class="home-metric">
                        <span>Usuarios</span>
                        <strong>@UsuariosGestao.Count</strong>
                        <small>Acessos ao sistema</small>
                    </article>
                    <article class="home-metric">
                        <span>Colaboradores</span>
                        <strong>@Colaboradores.Count</strong>
                        <small>Perfis e cargos do time</small>
                    </article>
                    <article class="home-metric">
                        <span>Empresas</span>
                        <strong>@Empresas.Count</strong>
                        <small>@StatusDemo</small>
                    </article>
                </div>
            </section>

            <section class="home-grid">
                <article class="card">
                    <h3>Conta e contexto</h3>
                    <div class="home-info-list">
                        <div>
                            <span>E-mail</span>
                            <strong>@Usuario.Email</strong>
                        </div>
                        <div>
                            <span>Cadastro</span>
                            <strong>@TextoDataCadastro</strong>
                        </div>
                        <div>
                            <span>Empresa principal</span>
                            <strong>@(EmpresaPrincipal?.Nome ?? "Ainda nao cadastrada")</strong>
                        </div>
                        <div>
                            <span>Status da demo</span>
                            <strong>@StatusDemo</strong>
                        </div>
                    </div>
                </article>

                <article class="card">
                    @if (Colaborador is not null)
                    {
                        <h3>Perfil do colaborador</h3>
                        <div class="home-info-list">
                            <div>
                                <span>Nome</span>
                                <strong>@Colaborador.Nome</strong>
                            </div>
                            <div>
                                <span>Cargo</span>
                                <strong>@Colaborador.Cargo</strong>
                            </div>
                            <div>
                                <span>Tipo</span>
                                <strong>@TipoUsuarioDescricao(Colaborador.TipoUsuario)</strong>
                            </div>
                            <div>
                                <span>Empresa</span>
                                <strong>@(EmpresaPrincipal?.Nome ?? "Nao vinculada")</strong>
                            </div>
                        </div>
                    }
                    else
                    {
                        <h3>Ative sua demonstracao</h3>
                        <p class="text-muted">Crie uma empresa de teste para liberar os primeiros 30 dias e concluir o bootstrap do ambiente.</p>

                        <input class="form-control" @bind="NomeEmpresaDemo" placeholder="Nome da empresa demo" />
                        <button class="btn btn-success mt-3" @onclick="AtivarPlanoDemo">Ativar demonstracao</button>

                        @if (!string.IsNullOrEmpty(Message))
                        {
                            <div class="alert @alertClass mt-3">@Message</div>
                        }
                    }
                </article>
            </section>

            <section class="home-action-bar">
                <button type="button" class="btn btn-outline-primary" @onclick="AbrirFormularioUsuario">Novo usuario</button>
                <button type="button" class="btn btn-outline-primary" @onclick="AbrirFormularioColaborador">Novo colaborador</button>
                <button type="button" class="btn btn-outline-primary" @onclick="AbrirFormularioCargo">Novo cargo</button>
                <button type="button" class="btn btn-outline-primary" @onclick="AbrirFormularioTipo">Novo tipo</button>
                <button type="button" class="btn btn-info" @onclick="IrParaEmpresas">Empresas</button>
            </section>

            @if (ResumoOperacao is not null)
            {
                <section class="home-grid">
                    <article class="card">
                        <div class="home-section-header">
                            <div>
                                <h3>Mesa operacional</h3>
                                <p class="text-muted">Uma leitura rapida da fila para o RH agir antes do backlog crescer.</p>
                            </div>
                        </div>

                        <div class="home-metric-grid home-metric-grid--operacao">
                            <article class="home-metric">
                                <span>Necessidades abertas</span>
                                <strong>@ResumoOperacao.TotalNecessidadesAbertas</strong>
                                <small>@ResumoOperacao.TotalNecessidadesCriticas criticas</small>
                            </article>
                            <article class="home-metric">
                                <span>Tarefas pendentes</span>
                                <strong>@ResumoOperacao.TotalTarefasPendentes</strong>
                                <small>@ResumoOperacao.TotalTarefasAtrasadas atrasadas</small>
                            </article>
                            <article class="home-metric">
                                <span>Sem responsavel</span>
                                <strong>@ResumoOperacao.TotalTarefasSemResponsavel</strong>
                                <small>Itens sem dono claro</small>
                            </article>
                            <article class="home-metric">
                                <span>Conclusao</span>
                                <strong>@ResumoOperacao.PercentualConclusaoTarefas.ToString("0.#")%</strong>
                                <small>Taxa de fechamento das tarefas</small>
                            </article>
                        </div>
                    </article>

                    <article class="card">
                        <div class="home-section-header">
                            <div>
                                <h3>Filas prioritarias</h3>
                                <p class="text-muted">Visibilidade de queue management para orientar a proxima acao.</p>
                            </div>
                        </div>

                        @if (ResumoOperacao.FilasNecessidades.Any())
                        {
                            <div class="home-list">
                                @foreach (var fila in ResumoOperacao.FilasNecessidades)
                                {
                                    <article class="home-list__item">
                                        <div>
                                            <strong>@fila.Label</strong>
                                            <p>@fila.Meta</p>
                                        </div>
                                        <div class="home-status-badge">@fila.Total</div>
                                    </article>
                                }
                            </div>
                        }
                    </article>
                </section>
            }

            <section class="home-grid home-grid--stack">
                <article class="card">
                    <div class="home-section-header">
                        <div>
                            <h3>Gestao de usuarios</h3>
                            <p class="text-muted">Controle os acessos e veja quais usuarios ja estao vinculados a um colaborador.</p>
                        </div>
                    </div>

                    @if (UsuariosGestao.Any())
                    {
                        <div class="home-list">
                            @foreach (var usuarioGestao in UsuariosGestao)
                            {
                                <article class="home-list__item">
                                    <div>
                                        <strong>@usuarioGestao.Email</strong>
                                        <p>
                                            @(string.IsNullOrWhiteSpace(usuarioGestao.ColaboradorNome)
                                                ? "Sem colaborador vinculado"
                                                : $"{usuarioGestao.ColaboradorNome} • {TipoUsuarioDescricao(usuarioGestao.TipoUsuario)}")
                                        </p>
                                    </div>
                                    <div class="home-list__actions">
                                        @if (usuarioGestao.ColaboradorId.HasValue || !string.IsNullOrWhiteSpace(usuarioGestao.ColaboradorNome))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary home-action-button" @onclick="() => AbrirEdicaoVinculo(usuarioGestao)">Editar cadastro</button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary home-action-button" @onclick="() => VincularUsuario(usuarioGestao)">Vincular colaborador</button>
                                        }

                                        <div class="home-status-badge">
                                            @usuarioGestao.DataCadastro.ToLocalTime().ToString("dd/MM/yyyy")
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Nenhum usuario cadastrado ainda.</p>
                    }
                </article>

                <article class="card">
                    <div class="home-section-header">
                        <div>
                            <h3>Colaboradores e tipos</h3>
                            <p class="text-muted">A logica operacional do app depende do tipo do colaborador. Aqui voce acompanha os perfis ativos na empresa.</p>
                        </div>
                    </div>

                    @if (Colaboradores.Any())
                    {
                        <div class="home-list">
                            @foreach (var colaboradorInfo in Colaboradores.OrderBy(c => c.Nome))
                            {
                                <article class="home-list__item">
                                    <div>
                                        <strong>@colaboradorInfo.Nome</strong>
                                        <p>@TipoUsuarioDescricao(colaboradorInfo.TipoUsuario) • @colaboradorInfo.Cargo</p>
                                        <small class="text-muted">CPF @FormatarCpf(colaboradorInfo.CPF)</small>
                                    </div>
                                    <div class="home-list__actions">
                                        @if (ExisteUsuarioGestao(colaboradorInfo.Email))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary home-action-button" @onclick="() => AbrirEdicaoVinculo(colaboradorInfo.Email)">Editar cadastro</button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary home-action-button" @onclick="() => AbrirCadastroUsuarioParaColaborador(colaboradorInfo)">Criar acesso</button>
                                        }
                                        <div class="home-status-badge">
                                            @colaboradorInfo.Email
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Nenhum colaborador carregado para a empresa atual.</p>
                    }
                </article>
            </section>

            <ActionDrawer IsOpen="ExibirFormularioUsuario"
                          Title="Novo usuario de acesso"
                          Subtitle="@(ColaboradorAcessoSelecionado is null
                              ? "Crie o acesso e depois vincule esse e-mail ao colaborador com o perfil correto."
                              : "Crie o acesso diretamente para o colaborador selecionado, mantendo e-mail e CPF alinhados ao cadastro.")"
                          OnClose="FecharFormularios">
                @if (ColaboradorAcessoSelecionado is not null)
                {
                    <div class="home-edit-context">
                        <span class="home-edit-context__label">Acesso para colaborador</span>
                        <strong>@ColaboradorAcessoSelecionado.Nome</strong>
                        <small>@ColaboradorAcessoSelecionado.Email • CPF @FormatarCpf(NovoUsuarioCpf)</small>
                    </div>
                }

                <div class="home-drawer-grid">
                    <div>
                        <label>E-mail</label>
                        <input type="email" class="form-control mb-2" @bind="NovoUsuarioEmail" />
                    </div>
                    @if (ColaboradorAcessoSelecionado is not null)
                    {
                        <div>
                            <label>CPF</label>
                            <input class="form-control mb-2" @bind="NovoUsuarioCpf" disabled />
                        </div>
                    }
                    <div>
                        <label>Senha</label>
                        <input type="password" class="form-control mb-2" @bind="NovaUsuarioSenha" />
                    </div>
                    <div>
                        <label>Confirmar senha</label>
                        <input type="password" class="form-control mb-2" @bind="ConfirmacaoUsuarioSenha" />
                    </div>
                </div>

                <div class="home-drawer-actions">
                    <button class="btn btn-success" @onclick="CadastrarUsuario">Salvar usuario</button>
                </div>

                @if (!string.IsNullOrEmpty(MessageUsuario))
                {
                    <div class="alert @(UsuarioSalvoComSucesso ? "alert-success" : "alert-danger") mt-3">@MessageUsuario</div>
                }
            </ActionDrawer>

            <ActionDrawer IsOpen="ExibirFormulario"
                          Title="Cadastro de colaborador"
                          Subtitle="Monte a base do time com empresa, cargo e tipo de acesso alinhados a regra do app."
                          OnClose="FecharFormularios">
                <div class="home-drawer-grid">
                    <div>
                        <label>Nome</label>
                        <input class="form-control mb-2" @bind="ColaboradorForm.Nome" />
                    </div>
                    <div>
                        <label>CPF</label>
                        <input class="form-control mb-2" @bind="ColaboradorForm.CPF" />
                    </div>
                    <div>
                        <label>E-mail</label>
                        <input type="email" class="form-control mb-2" @bind="ColaboradorForm.Email" />
                    </div>
                    <div>
                        <label>Tipo de usuario</label>
                        <select class="form-select mb-2" @bind="ColaboradorForm.TipoUsuario">
                            <option value="1">Usuario RH</option>
                            <option value="2">Usuario Apoio</option>
                            <option value="3">Usuario Colaborador</option>
                            <option value="4">Usuario Diretoria</option>
                        </select>
                    </div>
                    <div>
                        <label>Empresa</label>
                        <select class="form-select mb-2" @bind="ColaboradorForm.EmpresaId">
                            @foreach (var empresa in Empresas)
                            {
                                <option value="@empresa.EmpresaId">@empresa.Nome</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label>Cargo</label>
                        <div class="home-inline-input">
                            <select class="form-select" @bind="ColaboradorForm.Cargo">
                                <option value="">-- Selecione --</option>
                                @foreach (var cargo in Cargos)
                                {
                                    <option value="@cargo.Nome">@cargo.Nome</option>
                                }
                            </select>
                            <button class="btn btn-outline-primary" type="button" @onclick="ToggleNovoCargo">Novo cargo</button>
                        </div>
                    </div>
                    <div>
                        <label>Data de nascimento</label>
                        <InputDate @bind-Value="ColaboradorForm.DataNascimento" class="form-control mb-2" />
                    </div>
                    <div>
                        <label>Data de admissao</label>
                        <InputDate @bind-Value="ColaboradorForm.DataAdmissao" class="form-control mb-2" />
                    </div>
                    <div>
                        <label>Endereco</label>
                        <input class="form-control mb-2" @bind="ColaboradorForm.Endereco" />
                    </div>
                    <div>
                        <label>Genero</label>
                        <select class="form-select mb-3" @bind="ColaboradorForm.Genero">
                            <option value="">-- Selecione --</option>
                            <option value="Masculino">Masculino</option>
                            <option value="Feminino">Feminino</option>
                            <option value="Outros">Outros</option>
                        </select>
                    </div>
                </div>

                @if (ExibirNovoCargo)
                {
                    <div class="home-inline-panel">
                        <input class="form-control" @bind="NovoCargo.Nome" placeholder="Nome do novo cargo" />
                        <button class="btn btn-success" @onclick="CadastrarNovoCargo">Salvar cargo</button>
                    </div>

                    @if (!string.IsNullOrEmpty(MessageCargoInline))
                    {
                        <div class="alert alert-info mt-2">@MessageCargoInline</div>
                    }
                }

                <div class="home-drawer-actions">
                    <button class="btn btn-success" @onclick="CadastrarColaborador">Salvar colaborador</button>
                </div>

                @if (!string.IsNullOrEmpty(Message))
                {
                    <div class="alert @alertClass mt-3">@Message</div>
                }
            </ActionDrawer>

            <ActionDrawer IsOpen="ExibirFormularioCargo"
                          Title="Cadastro de cargo"
                          Subtitle="Adicione novos cargos e deixe a estrutura da equipe padronizada para cadastros futuros."
                          OnClose="FecharFormularios">
                <div class="home-drawer-grid">
                    <div>
                        <label>Nome do cargo</label>
                        <input class="form-control mb-2" @bind="CargoForm.Nome" />
                    </div>
                    <div>
                        <label>Empresa</label>
                        <select class="form-select mb-3" @bind="CargoForm.EmpresaId">
                            @foreach (var empresa in Empresas)
                            {
                                <option value="@empresa.EmpresaId">@empresa.Nome</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="home-drawer-actions">
                    <button class="btn btn-success" @onclick="CadastrarCargo">Salvar cargo</button>
                </div>

                @if (!string.IsNullOrEmpty(MessageCargo))
                {
                    <div class="alert @(CargoSalvoComSucesso ? "alert-success" : "alert-danger") mt-3">@MessageCargo</div>
                }
            </ActionDrawer>

            <ActionDrawer IsOpen="ExibirFormularioEdicaoVinculo"
                          Title="@TituloEdicaoVinculo"
                          Subtitle="@SubtituloEdicaoVinculo"
                          OnClose="FecharFormularios">
                <div class="home-edit-context">
                    <span class="home-edit-context__label">Cadastro em edicao</span>
                    <strong>@EdicaoVinculoForm.Nome</strong>
                    <small>@EdicaoVinculoForm.EmailAtual</small>
                </div>

                <div class="home-drawer-grid">
                    <div>
                        <label>E-mail atual</label>
                        <input type="email" class="form-control mb-2" value="@EdicaoVinculoForm.EmailAtual" disabled />
                    </div>
                    <div>
                        <label>Novo e-mail</label>
                        <input type="email" class="form-control mb-2" @bind="EdicaoVinculoForm.NovoEmail" />
                    </div>
                    <div>
                        <label>Nome</label>
                        <input class="form-control mb-2" @bind="EdicaoVinculoForm.Nome" />
                    </div>
                    <div>
                        <label>CPF</label>
                        <input class="form-control mb-2" @bind="EdicaoVinculoForm.CPF" />
                    </div>
                    <div>
                        <label>Tipo de usuario</label>
                        <select class="form-select mb-2" @bind="EdicaoVinculoForm.TipoUsuario">
                            <option value="1">Usuario RH</option>
                            <option value="2">Usuario Apoio</option>
                            <option value="3">Usuario Colaborador</option>
                            <option value="4">Usuario Diretoria</option>
                        </select>
                    </div>
                    <div>
                        <label>Empresa</label>
                        <select class="form-select mb-2" @bind="EdicaoVinculoForm.EmpresaId">
                            @foreach (var empresa in Empresas)
                            {
                                <option value="@empresa.EmpresaId">@empresa.Nome</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label>Cargo</label>
                        <select class="form-select mb-2" @bind="EdicaoVinculoForm.Cargo">
                            <option value="">-- Selecione --</option>
                            @foreach (var cargo in Cargos)
                            {
                                <option value="@cargo.Nome">@cargo.Nome</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="home-drawer-actions">
                    <button class="btn btn-success" @onclick="SalvarEdicaoVinculo">Salvar alteracoes</button>
                </div>

                @if (!string.IsNullOrEmpty(MessageEdicao))
                {
                    <div class="alert @(EdicaoSalvaComSucesso ? "alert-success" : "alert-danger") mt-3">@MessageEdicao</div>
                }
            </ActionDrawer>

            <ActionDrawer IsOpen="ExibirFormularioTipoNecessidade"
                          Title="Cadastro de tipo de necessidade"
                          Subtitle="Mantenha o catalogo de necessidades organizado para o dashboard e para a operacao."
                          OnClose="FecharFormularios">
                <div class="home-drawer-grid">
                    <div>
                        <label>Nome do tipo</label>
                        <input class="form-control mb-2" @bind="TipoNecessidadeForm.Nome" />
                    </div>
                    <div>
                        <label>Empresa</label>
                        <select class="form-select mb-3" @bind="TipoNecessidadeForm.EmpresaId">
                            @foreach (var empresa in Empresas)
                            {
                                <option value="@empresa.EmpresaId">@empresa.Nome</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="home-drawer-actions">
                    <button class="btn btn-success" @onclick="CadastrarTipoNecessidade">Salvar tipo</button>
                </div>

                @if (!string.IsNullOrEmpty(MessageTipo))
                {
                    <div class="alert @(TipoSalvoComSucesso ? "alert-success" : "alert-danger") mt-3">@MessageTipo</div>
                }
            </ActionDrawer>
        }
    </AppShell>
</AuthGuard>

@code {
    private UsuarioResponse? Usuario;
    private ColaboradorResponse? Colaborador;
    private bool Carregando = true;
    private string MensagemErro = string.Empty;
    private bool ExibirFormularioUsuario;
    private bool ExibirFormulario;
    private List<Empresa> Empresas = new();
    private List<UsuarioGestaoInfo> UsuariosGestao = new();
    private List<ColaboradorInfo> Colaboradores = new();
    private OperacaoResumoResponse? ResumoOperacao;
    private ColaboradorRequest ColaboradorForm = new();
    private string Message = string.Empty;
    private string alertClass = "alert-success";
    private bool ExibirFormularioCargo;
    private Cargo CargoForm = new();
    private string MessageCargo = string.Empty;
    private bool CargoSalvoComSucesso;
    private bool ExibirFormularioTipoNecessidade;
    private TipoNecessidade TipoNecessidadeForm = new();
    private string MessageTipo = string.Empty;
    private bool TipoSalvoComSucesso;
    private List<Cargo> Cargos = new();
    private bool ExibirNovoCargo;
    private Cargo NovoCargo = new();
    private string MessageCargoInline = string.Empty;
    private string NomeEmpresaDemo { get; set; } = string.Empty;
    private string NovoUsuarioEmail { get; set; } = string.Empty;
    private string NovoUsuarioCpf { get; set; } = string.Empty;
    private string NovaUsuarioSenha { get; set; } = string.Empty;
    private string ConfirmacaoUsuarioSenha { get; set; } = string.Empty;
    private string MessageUsuario = string.Empty;
    private bool UsuarioSalvoComSucesso;
    private ColaboradorInfo? ColaboradorAcessoSelecionado;
    private bool ExibirFormularioEdicaoVinculo;
    private UsuarioColaboradorUpdateRequest EdicaoVinculoForm = new();
    private string MessageEdicao = string.Empty;
    private bool EdicaoSalvaComSucesso;
    private string TituloEdicaoVinculo = "Editar usuario e colaborador";
    private string SubtituloEdicaoVinculo = "Ajuste e-mail, tipo, empresa, nome e cargo mantendo o vinculo da operacao.";

    private Empresa? EmpresaPrincipal =>
        Colaborador is null
            ? Empresas.FirstOrDefault()
            : Empresas.FirstOrDefault(e => e.EmpresaId == Colaborador.EmpresaId) ?? Empresas.FirstOrDefault();

    private string NomeApresentacao =>
        Colaborador?.Nome
        ?? Usuario?.Email.Split('@', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()
        ?? "time";

    private string TextoDataCadastro =>
        Usuario is null || Usuario.DataCadastro == default
            ? "Ainda nao registrado"
            : Usuario.DataCadastro.ToLocalTime().ToString("dd/MM/yyyy HH:mm");

    private string PerfilUsuario =>
        Colaborador is null ? "Configuracao inicial" : TipoUsuarioDescricao(Colaborador.TipoUsuario);

    private string StatusDemo
    {
        get
        {
            if (EmpresaPrincipal?.DataInicioDemo is null)
            {
                return "Demo ainda nao ativada";
            }

            var diasRestantes = Math.Max(0, 30 - (int)(DateTime.UtcNow - EmpresaPrincipal.DataInicioDemo.Value).TotalDays);
            return diasRestantes > 0
                ? $"{diasRestantes} dias restantes na demo"
                : "Periodo demo encerrado";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var email = await SessionService.GetUserEmailAsync();
            if (string.IsNullOrWhiteSpace(email))
            {
                Navigation.NavigateTo("/login", true);
                return;
            }

            var cargosTask = ApiService.GetCargosPorEmail(email);
            var empresasTask = ApiService.GetEmpresasAsync(email);
            var usuarioTask = ApiService.GetUsuarioInfo(email);
            var colaboradorTask = ApiService.GetColaboradorInfo(email);
            var usuariosTask = ApiService.GetUsuariosGestao(email);

            await Task.WhenAll(cargosTask, empresasTask, usuarioTask, colaboradorTask, usuariosTask);

            Cargos = cargosTask.Result ?? new();
            Empresas = empresasTask.Result ?? new();
            Usuario = usuarioTask.Result ?? new UsuarioResponse { Email = email };
            Colaborador = colaboradorTask.Result;
            UsuariosGestao = usuariosTask.Result ?? new();

            ApplyDefaultCompanySelections();

            await CarregarGestaoAsync(email);
            ResumoOperacao = await ApiService.GetResumoOperacao(email);
            NotificationService.Info("Visao geral carregada. Cadastros, perfis e operacao prontos para acompanhamento.");

            if (EmpresaPrincipal?.DataInicioDemo is not null)
            {
                var diasAtivos = (DateTime.UtcNow - EmpresaPrincipal.DataInicioDemo.Value).TotalDays;
                if (diasAtivos > 30)
                {
                    Navigation.NavigateTo("/expirado", true);
                    return;
                }
            }
        }
        catch
        {
            MensagemErro = "Erro ao carregar dados do usuario.";
        }
        finally
        {
            Carregando = false;
        }
    }

    private void ApplyDefaultCompanySelections()
    {
        var empresaId = EmpresaPrincipal?.EmpresaId ?? Empresas.FirstOrDefault()?.EmpresaId ?? 0;

        if (empresaId == 0)
        {
            return;
        }

        if (ColaboradorForm.EmpresaId == 0)
        {
            ColaboradorForm.EmpresaId = empresaId;
        }

        if (CargoForm.EmpresaId == 0)
        {
            CargoForm.EmpresaId = empresaId;
        }

        if (TipoNecessidadeForm.EmpresaId == 0)
        {
            TipoNecessidadeForm.EmpresaId = empresaId;
        }

        if (NovoCargo.EmpresaId == 0)
        {
            NovoCargo.EmpresaId = empresaId;
        }
    }

