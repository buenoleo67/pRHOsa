    private async Task CadastrarUsuario()
    {
        if (string.IsNullOrWhiteSpace(NovoUsuarioEmail) ||
            string.IsNullOrWhiteSpace(NovaUsuarioSenha) ||
            string.IsNullOrWhiteSpace(ConfirmacaoUsuarioSenha))
        {
            MessageUsuario = "Preencha e-mail, senha e confirmacao.";
            UsuarioSalvoComSucesso = false;
            return;
        }

        if (NovaUsuarioSenha != ConfirmacaoUsuarioSenha)
        {
            MessageUsuario = "As senhas nao coincidem.";
            UsuarioSalvoComSucesso = false;
            return;
        }

        if (ColaboradorAcessoSelecionado is not null && string.IsNullOrWhiteSpace(NovoUsuarioCpf))
        {
            MessageUsuario = "O colaborador precisa ter CPF para criar um acesso vinculado.";
            UsuarioSalvoComSucesso = false;
            return;
        }

        string resultado;

        if (ColaboradorAcessoSelecionado is not null)
        {
            resultado = await ApiService.CriarAcessoVinculado(new AcessoColaboradorRequest
            {
                ColaboradorId = ColaboradorAcessoSelecionado.Id,
                Email = NovoUsuarioEmail,
                CPF = NovoUsuarioCpf,
                Senha = NovaUsuarioSenha
            });
        }
        else
        {
            resultado = await ApiService.PostUsuario(NovoUsuarioEmail, NovaUsuarioSenha);
        }

        UsuarioSalvoComSucesso = resultado == "success";
        MessageUsuario = resultado == "success"
            ? (ColaboradorAcessoSelecionado is null
                ? "Usuario cadastrado com sucesso."
                : "Acesso criado e vinculado com sucesso.")
            : resultado;

        if (resultado == "success")
        {
            var emailAtual = await SessionService.GetUserEmailAsync();
            if (!string.IsNullOrWhiteSpace(emailAtual))
            {
                await CarregarGestaoAsync(emailAtual);
            }

            NovoUsuarioEmail = string.Empty;
            NovoUsuarioCpf = string.Empty;
            NovaUsuarioSenha = string.Empty;
            ConfirmacaoUsuarioSenha = string.Empty;
            ColaboradorAcessoSelecionado = null;
            NotificationService.Success("Usuario de acesso criado com sucesso.");
        }
    }

