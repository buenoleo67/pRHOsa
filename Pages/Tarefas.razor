@page "/Tarefas"
@inject API ApiService
@inject SessionService SessionService
@inject NavigationManager Navigation
@inject NotificationService NotificationService

<AuthGuard>
    <AppShell Title="Tarefas" Subtitle="Acompanhe o fluxo operacional, distribua responsabilidade e mantenha o historico de execucao visivel para o time.">
        <div class="page-container">
            <link href="css/necessidades.css" rel="stylesheet" />

            @if (!string.IsNullOrEmpty(Message))
            {
                <div class="alert @alertClass">@Message</div>
            }

            @if (CarregandoTarefas)
            {
                <div class="alert alert-info">Carregando tarefas...</div>
            }
            else if (!CarregandoTarefas && ListaTarefas.Count == 0)
            {
                <div class="alert alert-warning">Nenhuma tarefa encontrada.</div>
            }

            <div class="workspace-toolbar mb-3">
                <div class="workspace-toolbar__copy">
                    <span class="workspace-toolbar__eyebrow">Execucao</span>
                    <h3>Quadro de tarefas</h3>
                </div>
                <div class="workspace-toolbar__actions">
                    <button class="btn btn-primary" @onclick="AbrirFormularioNovaTarefa">+ Nova Tarefa</button>
                </div>
            </div>

            <p class="queue-helper-text">Abra os detalhes de uma tarefa para comentar, trocar responsavel e finalizar o fluxo com mais clareza.</p>

            @if (!CarregandoTarefas && ListaTarefas.Count > 0)
            {
                <div class="queue-summary-grid">
                    <article class="queue-summary-card">
                        <span>Pendentes</span>
                        <strong>@ListaTarefas.Count(t => t.Status is "Aberta" or "Em Andamento")</strong>
                        <small>Em execucao ativa</small>
                    </article>
                    <article class="queue-summary-card">
                        <span>Atrasadas</span>
                        <strong>@ListaTarefas.Count(TarefaEstaAtrasada)</strong>
                        <small>Prazos vencidos</small>
                    </article>
                    <article class="queue-summary-card">
                        <span>Sem responsavel</span>
                        <strong>@ListaTarefas.Count(t => !t.UsuarioResponsavelId.HasValue && TarefaPermiteEdicao(t))</strong>
                        <small>Precisam de distribuicao</small>
                    </article>
                    <article class="queue-summary-card">
                        <span>Concluidas</span>
                        <strong>@ListaTarefas.Count(t => t.Status == "Fechada")</strong>
                        <small>Historico finalizado</small>
                    </article>
                </div>

                <div class="queue-filter-bar">
                    @foreach (var filtro in FiltrosTarefa)
                    {
                        <button class="queue-filter @(FiltroTarefaAtivo == filtro ? "queue-filter--active" : "")"
                                @onclick="() => SelecionarFiltro(filtro)">
                            @filtro
                        </button>
                    }
                </div>

                <div class="d-flex flex-wrap gap-3">
                    @foreach (var status in StatusVisiveis)
                    {
                        <div class="kanban-column flex-fill">
                            <h5 class="text-center text-uppercase fw-bold">@status</h5>

                            @foreach (var tarefa in TarefasFiltradas.Where(t => t.Status == status))
                            {
                                <div class="kanban-card p-3 mb-3 rounded shadow-sm border @ObterClasseCard(tarefa.Status) @(TarefaEstaAtrasada(tarefa) ? "kanban-atrasada" : "")">
                                    <div class="kanban-card-header mb-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <strong>@tarefa.Descricao</strong>
                                            <span class="badge @ObterClasseStatus(tarefa.Status)">@tarefa.Status</span>
                                        </div>
                                        <div class="small text-muted">Contexto: @ObterContextoTarefa(tarefa)</div>
                                        <div class="small text-muted">Responsavel: @ObterNomeResponsavel(tarefa)</div>
                                        <div class="small text-muted">Prazo: @tarefa.DataLimite.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                        <div class="mt-2">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-primary queue-inline-action"
                                                    @onclick="() => SelecionarTarefa(tarefa)">
                                                @(TarefaSelecionada?.TarefaId == tarefa.TarefaId ? "Ocultar detalhes" : "Abrir detalhes")
                                            </button>
                                        </div>

                                        @if (TarefaPodeAtrasar(tarefa))
                                        {
                                            if (TarefaEstaAtrasada(tarefa))
                                            {
                                                <div class="text-danger fw-bold">Prazo vencido</div>
                                            }
                                            else
                                            {
                                                var restante = tarefa.DataLimite.ToLocalTime() - DateTime.Now;
                                                <div class="text-muted">@restante.Days d @restante.Hours h restantes</div>
                                            }
                                        }
                                    </div>

                                    @if (TarefaSelecionada?.TarefaId == tarefa.TarefaId)
                                    {
                                        <div class="tarefa-detalhes mt-3">
                                            <hr />

                                            @if (PodeGerenciarTarefas && TarefaPermiteEdicao(tarefa))
                                            {
                                                <div class="mb-2">
                                                    <label><strong>Alterar responsavel</strong></label>
                                                    <select class="form-select" @onchange="e => OnChangeResponsavel(e, tarefa.TarefaId)">
                                                        <option value="">-- Selecione --</option>
                                                        @foreach (var colab in Colaboradores)
                                                        {
                                                            <option value="@colab.Id" selected="@(TarefaSelecionada?.UsuarioResponsavelId == colab.Id)">
                                                                @colab.Nome
                                                            </option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            else if (!TarefaPermiteEdicao(tarefa))
                                            {
                                                <div class="alert alert-secondary small">
                                                    Edicao desativada: tarefa @tarefa.Status.ToUpper().
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="form-control bg-light text-muted">@ObterNomeResponsavel(tarefa)</div>
                                            }

                                            <p class="mb-1"><strong>Data de abertura:</strong> @tarefa.DataCriacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                                            @if (tarefa.PossuiNecessidadeVinculada)
                                            {
                                                <p class="mb-1"><strong>Necessidade:</strong> @tarefa.NecessidadeTitulo</p>
                                                <p class="mb-1"><strong>Tipo:</strong> @tarefa.TipoNecessidadeNome</p>
                                            }

                                            @if (TarefaPermiteEdicao(tarefa))
                                            {
                                                <div class="mb-2">
                                                    <label>Adicionar comentario</label>
                                                    <textarea class="form-control" @bind="NovoComentario"></textarea>
                                                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="AdicionarComentario">Salvar comentario</button>
                                                </div>
                                            }

                                            <div class="mt-3">
                                                <h6>Historico de comentarios</h6>
                                                @if (Comentarios.Count == 0)
                                                {
                                                    <p class="text-muted">Nenhum comentario ainda.</p>
                                                }
                                                else
                                                {
                                                    <ul class="list-group">
                                                        @foreach (var c in Comentarios)
                                                        {
                                                            <li class="list-group-item">
                                                                <b>@(string.IsNullOrWhiteSpace(c.AutorNome) ? c.Autor : c.AutorNome):</b> @c.Texto
                                                                <small class="text-muted">(@c.Data.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</small>
                                                            </li>
                                                        }
                                                    </ul>
                                                }

                                                @if (TarefaPermiteEdicao(tarefa))
                                                {
                                                    <div class="mt-3">
                                                        <button class="btn btn-outline-danger me-2" @onclick='() => AbrirEncerramento("Cancelada")'>Cancelar</button>
                                                        <button class="btn btn-outline-success" @onclick='() => AbrirEncerramento("Fechada")'>Finalizar</button>
                                                    </div>
                                                }

                                                @if (ExibirEncerramento && TarefaSelecionada?.TarefaId == tarefa.TarefaId)
                                                {
                                                    <div class="card p-3 mt-3 bg-light">
                                                        <h6>Comentario de encerramento</h6>
                                                        <textarea class="form-control" @bind="ComentarioEncerramento"></textarea>
                                                        <div class="mt-2 d-flex gap-2">
                                                            <button class="btn btn-primary" @onclick="ConfirmarEncerramento">Salvar</button>
                                                            <button class="btn btn-secondary" @onclick="FecharEncerramento">Cancelar</button>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            @if (!TarefasFiltradas.Any(t => t.Status == status))
                            {
                                <div class="text-center text-muted fst-italic">Nenhuma tarefa @status.ToLower().</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <ActionDrawer IsOpen="ExibirFormularioNovaTarefa"
                      Title="Nova tarefa"
                      Subtitle="Distribua o trabalho com urgencia e responsavel definidos sem quebrar o fluxo da tela."
                      OnClose="FecharFormularioNovaTarefa">
            <div class="drawer-form-grid">
                <div>
                    <label>Nivel de prazo</label>
                    <select class="form-select" @bind="Tarefa.Necessidade">
                        <option value="1">Alta</option>
                        <option value="2">Moderada</option>
                        <option value="3">Baixa</option>
                    </select>
                </div>

                <div>
                    <label>Responsavel</label>
                    <select class="form-select" @bind="Tarefa.UsuarioResponsavelId">
                        <option value="">-- Selecione um responsavel --</option>
                        @foreach (var colab in Colaboradores)
                        {
                            <option value="@colab.Id">@colab.Nome</option>
                        }
                    </select>
                </div>
            </div>

            <div class="mt-3">
                <label>Descricao</label>
                <textarea class="form-control drawer-textarea" @bind="Tarefa.Descricao"></textarea>
            </div>

            <div class="drawer-actions">
                <button class="btn btn-success" @onclick="CadastrarTarefa">Salvar tarefa</button>
            </div>
        </ActionDrawer>
    </AppShell>
</AuthGuard>

@code {
    private static readonly string[] StatusVisiveis = ["Aberta", "Em Andamento", "Fechada", "Cancelada"];
    private static readonly string[] FiltrosTarefa = ["Todas", "Atrasadas", "Sem responsavel", "Relacionadas a necessidades", "Concluidas"];

    private bool CarregandoTarefas = true;
    private bool ExibirFormularioNovaTarefa;
    private bool ExibirEncerramento;
    private string ComentarioEncerramento = string.Empty;
    private string? NovoStatusEncerramento;
    private string? UsuarioEmail;
    private string Message = string.Empty;
    private string alertClass = "alert-info";
    private List<ColaboradorInfo> Colaboradores = new();
    private TarefaRequest Tarefa = new() { Necessidade = 2 };
    private List<TarefaResponse> ListaTarefas = new();
    private TarefaResponse? TarefaSelecionada;
    private List<Comentario> Comentarios = new();
    private string NovoComentario = string.Empty;
    private ColaboradorResponse? Colaborador;
    private Empresa? EmpresaAtual;
    private string FiltroTarefaAtivo = "Todas";

    private bool PodeGerenciarTarefas => Colaborador?.TipoUsuario is 1 or 4;
    private IEnumerable<TarefaResponse> TarefasFiltradas => ListaTarefas.Where(AplicarFiltro);

    protected override async Task OnInitializedAsync()
    {
        UsuarioEmail = await SessionService.GetUserEmailAsync();

        if (string.IsNullOrWhiteSpace(UsuarioEmail))
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        Colaborador = await ApiService.GetColaboradorInfo(UsuarioEmail);

        var empresas = await ApiService.GetEmpresasAsync(UsuarioEmail) ?? new();
        EmpresaAtual = Colaborador is null
            ? empresas.FirstOrDefault()
            : empresas.FirstOrDefault(e => e.EmpresaId == Colaborador.EmpresaId) ?? empresas.FirstOrDefault();

        if (EmpresaAtual?.DataInicioDemo is not null)
        {
            var dias = (DateTime.UtcNow - EmpresaAtual.DataInicioDemo.Value).TotalDays;
            if (dias > 30)
            {
                Navigation.NavigateTo("/expirado", true);
                return;
            }
        }

        if (EmpresaAtual is not null)
        {
            Colaboradores = await ApiService.GetColaboradoresAsync(EmpresaAtual.EmpresaId) ?? new();
        }

        await CarregarTarefas();
        NotificationService.Info("Quadro de tarefas carregado com sucesso.");
    }

    private async Task CarregarTarefas()
    {
        if (string.IsNullOrWhiteSpace(UsuarioEmail))
        {
            ListaTarefas = new();
            return;
        }

        CarregandoTarefas = true;
        ListaTarefas = await ApiService.GetTarefasPainel(UsuarioEmail) ?? new();
        CarregandoTarefas = false;
    }

    private void AbrirFormularioNovaTarefa()
    {
        ExibirFormularioNovaTarefa = true;
        LimparMensagem();
    }

    private void FecharFormularioNovaTarefa()
    {
        ExibirFormularioNovaTarefa = false;
        LimparMensagem();
    }

    private async Task CadastrarTarefa()
    {
        if (string.IsNullOrWhiteSpace(UsuarioEmail))
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(Tarefa.Descricao))
        {
            DefinirMensagem("Informe uma descricao para a tarefa.", "alert-danger");
            return;
        }

        if (Tarefa.UsuarioResponsavelId is null)
        {
            DefinirMensagem("Selecione um responsavel para a tarefa.", "alert-danger");
            return;
        }

        Tarefa.DataCriacao = DateTime.UtcNow;
        Tarefa.Status = "Aberta";
        Tarefa.DataLimite = Tarefa.Necessidade switch
        {
            1 => Tarefa.DataCriacao.AddHours(6),
            2 => Tarefa.DataCriacao.AddHours(12),
            3 => Tarefa.DataCriacao.AddDays(1),
            _ => Tarefa.DataCriacao.AddDays(1)
        };

        Tarefa.ResponsavelEmail = Colaboradores.FirstOrDefault(c => c.Id == Tarefa.UsuarioResponsavelId)?.Email ?? string.Empty;

        var resultado = await ApiService.PostTarefa(UsuarioEmail, Tarefa);
        if (resultado == "success")
        {
            DefinirMensagem("Tarefa cadastrada com sucesso.", "alert-success");
            NotificationService.Success("Tarefa aberta com sucesso.");
            Tarefa = new TarefaRequest { Necessidade = 2 };
            FecharFormularioNovaTarefa();
            await CarregarTarefas();
        }
        else
        {
            DefinirMensagem($"Erro: {resultado}", "alert-danger");
        }
    }

    private async Task SelecionarTarefa(TarefaResponse tarefa)
    {
        ExibirEncerramento = false;
        ComentarioEncerramento = string.Empty;
        NovoComentario = string.Empty;

        if (TarefaSelecionada?.TarefaId == tarefa.TarefaId)
        {
            TarefaSelecionada = null;
            Comentarios.Clear();
            return;
        }

        TarefaSelecionada = tarefa;
        Comentarios = await ApiService.GetComentariosPorTarefa(tarefa.TarefaId) ?? new();
    }

    private async Task AdicionarComentario()
    {
        if (TarefaSelecionada is null || string.IsNullOrWhiteSpace(NovoComentario) || string.IsNullOrWhiteSpace(UsuarioEmail))
        {
            return;
        }

        var comentario = new Comentario
        {
            Autor = UsuarioEmail,
            AutorNome = Colaborador?.Nome ?? UsuarioEmail,
            Texto = NovoComentario.Trim(),
            Data = DateTime.UtcNow
        };

        var sucesso = await ApiService.AdicionarComentarioAsync(TarefaSelecionada.TarefaId, comentario);
        if (sucesso)
        {
            Comentarios.Add(comentario);
            NovoComentario = string.Empty;
            NotificationService.Success("Comentario registrado com sucesso.");
        }
    }

    private static string FormatarNivelPrazo(int n) => n switch
    {
        1 => "Alta",
        2 => "Moderada",
        3 => "Baixa",
        _ => "Desconhecida"
    };

    private string ObterNomeResponsavel(TarefaResponse tarefa)
    {
        if (!string.IsNullOrWhiteSpace(tarefa.ResponsavelNome))
        {
            return tarefa.ResponsavelNome;
        }

        if (!tarefa.UsuarioResponsavelId.HasValue)
        {
            return "Nao atribuido";
        }

        return Colaboradores.FirstOrDefault(c => c.Id == tarefa.UsuarioResponsavelId.Value)?.Nome ?? "Responsavel desconhecido";
    }

    private void AbrirEncerramento(string status)
    {
        NovoStatusEncerramento = status;
        ExibirEncerramento = true;
    }

    private void FecharEncerramento()
    {
        ExibirEncerramento = false;
        ComentarioEncerramento = string.Empty;
        NovoStatusEncerramento = null;
    }

    private async Task ConfirmarEncerramento()
    {
        if (string.IsNullOrWhiteSpace(ComentarioEncerramento) || TarefaSelecionada is null || string.IsNullOrWhiteSpace(UsuarioEmail))
        {
            return;
        }

        var sucessoStatus = await ApiService.AtualizarStatusTarefaAsync(TarefaSelecionada.TarefaId, NovoStatusEncerramento!);

        var comentario = new Comentario
        {
            Autor = UsuarioEmail,
            AutorNome = Colaborador?.Nome ?? UsuarioEmail,
            Texto = $"[Encerramento - {NovoStatusEncerramento}] {ComentarioEncerramento.Trim()}",
            Data = DateTime.UtcNow
        };

        var sucessoComentario = await ApiService.AdicionarComentarioAsync(TarefaSelecionada.TarefaId, comentario);
        if (sucessoStatus && sucessoComentario)
        {
            TarefaSelecionada.Status = NovoStatusEncerramento!;
            Comentarios.Add(comentario);
            FecharEncerramento();
            await CarregarTarefas();
            NotificationService.Success($"Tarefa {NovoStatusEncerramento!.ToLowerInvariant()} com sucesso.");
        }
    }

    private async Task OnChangeResponsavel(ChangeEventArgs e, int tarefaId)
    {
        if (!int.TryParse(e.Value?.ToString(), out var novoResponsavelId))
        {
            return;
        }

        var sucesso = await ApiService.AtualizarResponsavelTarefaAsync(tarefaId, novoResponsavelId);
        if (sucesso)
        {
            var tarefa = ListaTarefas.FirstOrDefault(t => t.TarefaId == tarefaId);
            if (tarefa is not null)
            {
                tarefa.UsuarioResponsavelId = novoResponsavelId;
            }

            if (TarefaSelecionada?.TarefaId == tarefaId)
            {
                TarefaSelecionada.UsuarioResponsavelId = novoResponsavelId;
            }

            DefinirMensagem("Responsavel atualizado com sucesso.", "alert-success");
            NotificationService.Success("Responsavel atualizado com sucesso.");
        }
        else
        {
            DefinirMensagem("Erro ao atualizar responsavel.", "alert-danger");
        }
    }

    private static string ObterClasseStatus(string status) => status switch
    {
        "Cancelada" => "status-cancelada",
        "Fechada" => "status-fechada",
        "Em Andamento" => "bg-primary text-white",
        _ => "bg-info text-white"
    };

    private static string ObterClasseCard(string status) => status switch
    {
        "Cancelada" => "status-card-cancelada",
        "Fechada" => "status-card-fechada",
        "Em Andamento" => "bg-light border-primary",
        _ => "bg-light border-info"
    };

    private static bool TarefaPermiteEdicao(TarefaResponse tarefa) =>
        tarefa.Status is not "Fechada" and not "Cancelada";

    private static bool TarefaPodeAtrasar(TarefaResponse tarefa) =>
        tarefa.Status is "Aberta" or "Em Andamento";

    private static bool TarefaEstaAtrasada(TarefaResponse tarefa) =>
        TarefaPodeAtrasar(tarefa) && DateTime.Now > tarefa.DataLimite.ToLocalTime();

    private string ObterContextoTarefa(TarefaResponse tarefa) =>
        tarefa.PossuiNecessidadeVinculada
            ? $"{tarefa.NecessidadeTitulo} • {tarefa.TipoNecessidadeNome}"
            : $"Tarefa avulsa • Prazo {FormatarNivelPrazo(tarefa.Necessidade)}";

    private bool AplicarFiltro(TarefaResponse tarefa) => FiltroTarefaAtivo switch
    {
        "Atrasadas" => TarefaEstaAtrasada(tarefa),
        "Sem responsavel" => !tarefa.UsuarioResponsavelId.HasValue && TarefaPermiteEdicao(tarefa),
        "Relacionadas a necessidades" => tarefa.PossuiNecessidadeVinculada,
        "Concluidas" => tarefa.Status == "Fechada",
        _ => true
    };

    private void SelecionarFiltro(string filtro)
    {
        FiltroTarefaAtivo = filtro;
    }

    private void DefinirMensagem(string mensagem, string classe)
    {
        Message = mensagem;
        alertClass = classe;
    }

    private void LimparMensagem()
    {
        Message = string.Empty;
        alertClass = "alert-info";
    }
}
